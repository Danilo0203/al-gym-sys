<service>
  <id>allgym-web</id>
  <name>All Gym Web</name>
  <description>Next.js standalone LAN frontend service for All Gym.</description>

  <executable>powershell.exe</executable>
  <arguments>-NoProfile -ExecutionPolicy Bypass -File "C:\Program Files\AllGym\scripts\start-allgym-web.ps1"</arguments>
  <workingdirectory>C:\Program Files\AllGym\allgym-web</workingdirectory>

  <startmode>Automatic</startmode>
  <stoptimeout>15sec</stoptimeout>
  <priority>Normal</priority>

  <logpath>C:\ProgramData\AllGym\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>8</keepFiles>
  </log>

  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="20 sec" />
  <onfailure action="none" />
</service>
