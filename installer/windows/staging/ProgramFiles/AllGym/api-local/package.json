{
  "name": "api-local",
  "version": "0.1.0",
  "private": true,
  "description": "Backend local minimo de All Gym para auth y sesiones sobre PostgreSQL 16.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "bootstrap:admin": "tsx src/scripts/bootstrap-admin.ts",
    "stage:windows:api": "node scripts/stage-windows-api-local.mjs",
    "build:windows:api": "npm run build && npm run stage:windows:api"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
